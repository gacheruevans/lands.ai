APP_NAME=lands.ai backend
APP_VERSION=0.1.0
API_PREFIX=/api/v1

DEFAULT_LLM_PROVIDER=openai-compatible
LLM_API_KEY=replace_me
OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini

# Embedding provider (can differ from chat provider)
# Example: use Groq for chat but OpenAI for embeddings:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_API_KEY=gsk_...
#   EMBEDDING_BASE_URL=https://api.openai.com/v1
#   EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
RETRIEVAL_TOP_K=4
RETRIEVAL_CANDIDATE_POOL=12
MIN_CITATION_SCORE=0.48
MIN_ANSWER_CONFIDENCE=0.60
MIN_CITATIONS_REQUIRED=1
CHUNK_TARGET_CHARS=850
CHUNK_MAX_CHARS=1100
CHUNK_OVERLAP_SENTENCES=1
ENABLE_ONLINE_RESEARCH=true
ONLINE_RESEARCH_MAX_DOCS=1
ONLINE_RESEARCH_MIN_CHARS=180
ONLINE_RESEARCH_TIMEOUT_SECONDS=15
ONLINE_RESEARCH_MIN_RELEVANCE_SCORE=0.28
ONLINE_RESEARCH_QUERY_SUFFIX="Kenya land property ownership stamp duty transfer law"
ONLINE_RESEARCH_SEARCH_URL=https://en.wikipedia.org/w/api.php
ONLINE_RESEARCH_EXTRACT_URL=https://en.wikipedia.org/w/api.php
ONLINE_RESEARCH_USER_AGENT="lands.ai/0.1 (research assistant; contact: dev@lands.ai)"

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/lands_ai
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
